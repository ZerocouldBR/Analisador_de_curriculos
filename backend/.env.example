# ============================================================
# Analisador de Curriculos - Variaveis de Ambiente
# ============================================================
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
#
# Ou use o script de setup automatico:
#   python setup.py local   (desenvolvimento)
#   python setup.py vps     (producao)
# ============================================================

# ============================================================
# Aplicacao
# ============================================================
APP_VERSION=0.3.0
LOG_LEVEL=INFO
DEBUG=true

# ============================================================
# Banco de Dados PostgreSQL
# ============================================================
# Local (sem Docker):
DATABASE_URL=postgresql+psycopg://analisador:analisador@localhost:5432/analisador_curriculos
# Docker Compose:
# DATABASE_URL=postgresql+psycopg://analisador:analisador@db:5432/analisador_curriculos

# ============================================================
# Redis (cache e filas)
# ============================================================
# Local (sem Docker):
REDIS_URL=redis://localhost:6379/0
# Docker Compose:
# REDIS_URL=redis://redis:6379/0
# Docker Compose Producao (com senha):
# REDIS_URL=redis://:SUA_SENHA@redis:6379/0

# ============================================================
# Autenticacao JWT (OBRIGATORIO em producao)
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Se nao definido, o app gera uma chave temporaria (invalidada a cada restart)
# ============================================================
SECRET_KEY=ALTERE_ESTA_CHAVE_SECRETA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# CORS (origens permitidas, formato JSON)
# ============================================================
CORS_ORIGINS=["http://localhost:3000"]

# ============================================================
# OpenAI (para embeddings e chat LLM)
# ============================================================
# OPENAI_API_KEY=sk-your-api-key-here
# CHAT_MODEL=gpt-4-turbo-preview
# EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# Vector DB Provider: pgvector (padrao), supabase, qdrant
# ============================================================
VECTOR_DB_PROVIDER=pgvector

# ============================================================
# Embeddings (modo: api = OpenAI, code = local sentence-transformers)
# ============================================================
EMBEDDING_MODE=api

# ============================================================
# LinkedIn (opcional)
# ============================================================
# LINKEDIN_API_ENABLED=false
# LINKEDIN_API_PROVIDER=none
# PROXYCURL_API_KEY=your-proxycurl-api-key
# LINKEDIN_CLIENT_ID=your-client-id
# LINKEDIN_CLIENT_SECRET=your-client-secret

# ============================================================
# Storage (local, s3, minio)
# ============================================================
# STORAGE_BACKEND=local
# STORAGE_PATH=./uploads
