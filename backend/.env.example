# ============================================================
# Analisador de Curriculos - Variaveis de Ambiente
# ============================================================
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
#
# Ou use o script de setup automatico:
#   python setup.py local   (desenvolvimento)
#   python setup.py vps     (producao)
# ============================================================

# ============================================================
# Aplicacao
# ============================================================
APP_VERSION=0.3.0
LOG_LEVEL=INFO
DEBUG=true

# ============================================================
# Banco de Dados PostgreSQL
# ============================================================
# Local (sem Docker):
DATABASE_URL=postgresql+psycopg://analisador:analisador@localhost:5432/analisador_curriculos
# Docker Compose:
# DATABASE_URL=postgresql+psycopg://analisador:analisador@db:5432/analisador_curriculos
# Supabase (conexao direta PostgreSQL):
# DATABASE_URL=postgresql+psycopg://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Schema do banco de dados (default: public)
# Use um schema customizado para isolar tabelas em PostgreSQL compartilhado ou Supabase
# O schema sera criado automaticamente pelo init_db
DATABASE_SCHEMA=public

# Pool de conexoes
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
# DATABASE_POOL_TIMEOUT=30

# ============================================================
# Redis (cache e filas)
# ============================================================
# Local (sem Docker):
REDIS_URL=redis://localhost:6379/0
# Docker Compose:
# REDIS_URL=redis://redis:6379/0
# Docker Compose Producao (com senha):
# REDIS_URL=redis://:SUA_SENHA@redis:6379/0

# ============================================================
# Autenticacao JWT (OBRIGATORIO em producao)
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Se nao definido, o app gera uma chave temporaria (invalidada a cada restart)
# ============================================================
SECRET_KEY=ALTERE_ESTA_CHAVE_SECRETA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# CORS (origens permitidas, formato JSON)
# ============================================================
CORS_ORIGINS=["http://localhost:3000"]

# ============================================================
# Provedor de IA (OpenAI ou Anthropic)
# ============================================================
# Escolha o provedor: openai ou anthropic
# Anthropic e o padrao: habilita prompt caching (reduz ~90% do custo de
# input tokens em chamadas repetidas) e extended thinking (melhora
# assertividade em curriculos ambiguos).
LLM_PROVIDER=anthropic

# OpenAI (para LLM quando provider=openai, e sempre para embeddings via API)
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_BASE_URL=                    # Deixe vazio para padrao

# Anthropic (para LLM quando provider=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_BASE_URL=                  # Deixe vazio para padrao

# Modelo LLM (deve ser compativel com o provedor escolhido)
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4, gpt-3.5-turbo
# Anthropic: claude-sonnet-4-5, claude-opus-4-5, claude-haiku-4-5-20251001
CHAT_MODEL=claude-sonnet-4-5

# Extended thinking (apenas Anthropic): budget de tokens para
# re-extracao quando a confianca esta abaixo do limiar.
# 0 desabilita. Recomendado: 4000-8000 para maxima assertividade.
# EXTRACTION_THINKING_BUDGET=0
# EXTRACTION_LOW_CONFIDENCE_THRESHOLD=0.6
# EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# Embeddings (modo: api = OpenAI, code = local sentence-transformers)
# ============================================================
EMBEDDING_MODE=api
# EMBEDDING_DIMENSIONS=1536          # Para modo API (OpenAI text-embedding-3-small)
# EMBEDDING_LOCAL_DIMENSIONS=384     # Para modo code (all-MiniLM-L6-v2)
# EMBEDDING_LOCAL_MODEL=all-MiniLM-L6-v2
# EMBEDDING_LOCAL_DEVICE=cpu         # cpu, cuda, mps

# ============================================================
# Vector DB - Provedores de Banco Vetorial
# ============================================================
# Provedor principal (define qual e usado para buscas)
VECTOR_DB_PROVIDER=pgvector
VECTOR_DB_PRIMARY=pgvector

# Habilitacao individual (multiplos podem estar ativos simultaneamente)
# Escritas sao enviadas a todos os habilitados (fan-out)
PGVECTOR_ENABLED=true
SUPABASE_ENABLED=false
QDRANT_ENABLED=false

# --- pgvector (PostgreSQL local) ---
# URL separada para pgvector (se diferente do DATABASE_URL):
# PGVECTOR_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db
# PGVECTOR_HNSW_M=16
# PGVECTOR_HNSW_EF_CONSTRUCTION=64
# PGVECTOR_HNSW_EF_SEARCH=100
# PGVECTOR_DISTANCE_METRIC=cosine   # cosine, l2, inner_product

# --- Supabase (PostgreSQL gerenciado + pgvector) ---
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_TABLE_NAME=embeddings
# SUPABASE_FUNCTION_NAME=match_embeddings
# Para gerar o SQL de setup do Supabase:
#   python -m app.db.init_db --supabase-sql

# --- Qdrant (banco vetorial dedicado) ---
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key
# QDRANT_COLLECTION_NAME=curriculos
# QDRANT_GRPC_PORT=6334
# QDRANT_PREFER_GRPC=true

# ============================================================
# LinkedIn (opcional)
#
# Todas estas variaveis tambem podem ser definidas em
# Configuracoes > LinkedIn (o banco tem prioridade sobre o .env).
# ============================================================
# LINKEDIN_API_ENABLED=false
# LINKEDIN_API_PROVIDER=none              # none | proxycurl | rapidapi | official

# --- Proxycurl (recomendado) ---
# PROXYCURL_API_KEY=your-proxycurl-api-key
# PROXYCURL_BASE_URL=https://nubela.co/proxycurl

# --- RapidAPI ---
# RAPIDAPI_KEY=your-rapidapi-key
# RAPIDAPI_HOST=linkedin-profile-data.p.rapidapi.com
# RAPIDAPI_PROFILE_ENDPOINT=/profile
# RAPIDAPI_URL_PARAM=url

# --- API Oficial LinkedIn (OAuth) ---
# LINKEDIN_CLIENT_ID=your-client-id
# LINKEDIN_CLIENT_SECRET=your-client-secret
# LINKEDIN_REDIRECT_URI=https://meusite.com/api/v1/linkedin/callback

# --- Comportamento de busca ---
# LINKEDIN_REQUEST_TIMEOUT=30
# LINKEDIN_SEARCH_COUNTRY=BR
# LINKEDIN_SEARCH_RESULTS_LIMIT=50
# LINKEDIN_INTERNAL_SEARCH_LIMIT=200
# LINKEDIN_ENRICHMENT_SCORE_WEIGHT=0.3

# ============================================================
# Sourcing Hibrido (multi-source candidate management)
# ============================================================
# SOURCING_ENABLED=false
# SOURCING_SYNC_INTERVAL_DAYS=5
# SOURCING_DEDUP_THRESHOLD=0.7

# ============================================================
# Storage (local, s3, minio)
# ============================================================
# STORAGE_BACKEND=local
# STORAGE_PATH=./uploads

# ============================================================
# Multi-Tenant / Empresas
# ============================================================
# MULTI_TENANT_ENABLED=true

# ============================================================
# Precificacao IA
# ============================================================
# AI_PRICING_ENABLED=true
# AI_CURRENCY=USD
# AI_CURRENCY_EXCHANGE_RATE=1.0
