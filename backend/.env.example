# ============================================================
# Aplicação
# ============================================================
APP_VERSION=0.3.0
LOG_LEVEL=INFO
DEBUG=false

# ============================================================
# Banco de Dados PostgreSQL
# Para Docker: use 'db' como host
# Para local: use 'localhost' como host
# ============================================================
DATABASE_URL=postgresql+psycopg://analisador:analisador@db:5432/analisador_curriculos

# ============================================================
# Redis (cache e filas)
# Para Docker: use 'redis' como host
# Para local: use 'localhost' como host
# Para produção com senha: redis://:SUA_SENHA@redis:6379/0
# ============================================================
REDIS_URL=redis://redis:6379/0

# ============================================================
# Autenticação JWT (OBRIGATÓRIO - gere com: python -c "import secrets; print(secrets.token_urlsafe(32))")
# ============================================================
SECRET_KEY=ALTERE_ESTA_CHAVE_SECRETA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# CORS (origens permitidas, formato JSON)
# ============================================================
CORS_ORIGINS=["http://localhost:3000"]

# ============================================================
# OpenAI (para embeddings e chat LLM)
# ============================================================
# OPENAI_API_KEY=sk-your-api-key-here
# CHAT_MODEL=gpt-4-turbo-preview
# EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# Vector DB Provider: pgvector (padrão), supabase, qdrant
# ============================================================
VECTOR_DB_PROVIDER=pgvector

# ============================================================
# Embeddings (modo: api = OpenAI, code = local sentence-transformers)
# ============================================================
EMBEDDING_MODE=api

# ============================================================
# LinkedIn (opcional)
# ============================================================
# LINKEDIN_API_ENABLED=false
# LINKEDIN_CLIENT_ID=your-client-id
# LINKEDIN_CLIENT_SECRET=your-client-secret

# ============================================================
# Storage (local, s3, minio)
# ============================================================
# STORAGE_BACKEND=local
# STORAGE_PATH=./uploads

# ============================================================
# Docker Compose Production - variáveis adicionais
# (defina no shell ou em .env na raiz do projeto)
# ============================================================
# DB_PASSWORD=senha_segura_do_postgres
# REDIS_PASSWORD=senha_segura_do_redis
# FLOWER_USER=admin
# FLOWER_PASSWORD=senha_segura_do_flower
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=senha_segura_do_grafana
# FRONTEND_API_URL=https://curriculos.seudominio.com.br
# FRONTEND_WS_URL=wss://curriculos.seudominio.com.br
